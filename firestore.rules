
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the authenticated user's UID matches the provided userId.
     * This is the primary function for enforcing document ownership.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if the authenticated user has the "Owner" role by verifying
     * the existence of a corresponding document in the roles_owner collection.
     */
    function isOwnerRole() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_owner/$(request.auth.uid));
    }

    /**
     * Validates that the ID within a new Manager document matches the document's path ID.
     * Enforces relational integrity on creation.
     */
    function isValidManagerCreate(managerId) {
      return request.resource.data.id == managerId;
    }

    /**
     * Ensures the manager's unique ID field is immutable upon update.
     */
    function isImmutableManagerId() {
      return request.resource.data.id == resource.data.id;
    }
    
    /**
     * Validates that the managerId within a new Bill document matches the managerId from the path.
     * Enforces relational integrity for user-scoped subcollections.
     */
    function isValidSubcollectionBillCreate(managerId) {
      return request.resource.data.managerId == managerId;
    }
    
    /**
     * Validates that the managerId of an incoming bill being created in the global
     * collection matches the UID of the user creating it.
     */
    function isValidGlobalBillCreate() {
      return request.resource.data.managerId == request.auth.uid;
    }
    
    /**
     * Ensures the managerId field on any Bill document is immutable.
     */
    function isImmutableBillManagerId() {
      return request.resource.data.managerId == resource.data.managerId;
    }
    
    /**
     * Validates that the managerId of an incoming notification matches the UID of the user creating it.
     */
    function isValidNotificationCreate() {
      return request.resource.data.managerId == request.auth.uid;
    }

    /**
     * Validates that the managerId of an incoming labour record matches the UID of the user creating it.
     */
    function isValidLabourCreate() {
        return request.resource.data.managerId == request.auth.uid;
    }

    // -------------------------------------------------------------------------
    // Collection Rules
    // -------------------------------------------------------------------------

    /**
     * @description Rules for manager profile documents. Only the manager themselves can create, view, or edit their own profile.
     * @path /managers/{managerId}
     * @allow (create) An authenticated user creating their own manager profile: auth.uid === managerId.
     * @deny (get) A manager trying to read another manager's profile: auth.uid !== managerId.
     * @deny (list) Any user trying to list all managers in the system.
     * @principle Restricts access to a user's own data tree and prevents user enumeration.
     */
    match /managers/{managerId} {
      allow get: if isOwner(managerId);
      allow list: if false;
      allow create: if isOwner(managerId) && isValidManagerCreate(managerId);
      allow update: if isOwner(managerId) && isImmutableManagerId();
      allow delete: if isOwner(managerId);

      /**
       * @description Rules for a manager's private bills subcollection. Access is granted if the user is the owner of the parent manager document.
       * @path /managers/{managerId}/bills/{billId}
       * @allow (list) A manager listing their own created bills.
       * @deny (get) A manager trying to read a bill from another manager's subcollection.
       * @principle Enforces hierarchical ownership; permissions are inherited from the parent document.
       */
      match /bills/{billId} {
        allow get: if isOwner(managerId) || isOwnerRole();
        allow list: if isOwner(managerId);
        allow create: if isOwner(managerId) && isValidSubcollectionBillCreate(managerId);
        allow update: if isOwner(managerId) && isImmutableBillManagerId();
        allow delete: if isOwner(managerId) || isOwnerRole();
      }
    }

    /**
     * @description Defines user roles. The existence of a document here grants owner privileges.
     * @path /roles_owner/{ownerId}
     * @allow (create) A user creating their own owner role document.
     * @deny (get) Another user trying to read someone else's owner role document.
     * @deny (list) Any user trying to list all owners.
     * @principle Secures role-granting documents and prevents user enumeration.
     */
    match /roles_owner/{ownerId} {
      allow get: if isOwner(ownerId);
      allow list: if false;
      // In production, creation might be restricted to an admin role or Cloud Function.
      // For prototyping, self-creation is permitted.
      allow create: if isOwner(ownerId) && request.resource.data.id == ownerId;
      allow update: if isOwner(ownerId) && request.resource.data.id == resource.data.id;
      allow delete: if isOwner(ownerId);
    }
    
    /**
     * @description A global collection of all bills, designed for owner oversight.
     *              Owners have full read access. Managers can only create bills, or update/delete their own specific bills.
     * @path /bills/{billId}
     * @allow (list) An Owner listing all bills in the system for reporting.
     * @deny (list) A Manager attempting to list all bills.
     * @allow (update) A Manager updating a bill they previously created (resource.data.managerId === auth.uid).
     * @deny (update) An Owner trying to modify a manager's bill.
     * @principle Segregates access patterns: global read for roles, specific write for owners.
     */
    match /bills/{billId} {
      allow get: if isOwnerRole() || isOwner(resource.data.managerId);
      allow list: if isOwnerRole();
      allow create: if isSignedIn() && isValidGlobalBillCreate();
      allow update: if isOwner(resource.data.managerId) && isImmutableBillManagerId();
      allow delete: if isOwner(resource.data.managerId) || isOwnerRole();
    }

    /**
     * @description Global application settings, such as billing rates.
     * @path /app_settings/{settingsId}
     * @allow (get, list) All authenticated users can read the settings.
     * @allow (create, update, delete) Only users with the 'Owner' role can modify the settings.
     * @principle Allows public read access for application configuration while restricting write access to administrators.
     */
    match /app_settings/{settingsId} {
      allow read: if isSignedIn();
      allow write: if isOwnerRole();
    }

    /**
     * @description A global collection of all notifications.
     * @path /notifications/{notificationId}
     * @allow (read) Any authenticated user can read notifications.
     * @allow (create) Any authenticated manager can create a notification.
     * @deny (update) No one can update notifications to maintain an immutable log.
     * @allow (delete) Any authenticated user can delete a notification.
     */
    match /notifications/{notificationId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && isValidNotificationCreate();
        allow update: if false;
        allow delete: if isSignedIn();
    }

    /**
     * @description Collection for storing individual labour charge records.
     * @path /labours/{labourId}
     * @allow (create) Any authenticated manager can create a labour record.
     * @allow (list) All authenticated users can list records.
     * @allow (get, update, delete) Only the manager who created the record or an owner can access/modify it.
     */
    match /labours/{labourId} {
        allow get: if isOwner(resource.data.managerId) || isOwnerRole();
        allow list: if isSignedIn();
        allow create: if isSignedIn() && isValidLabourCreate();
        allow update, delete: if isOwner(resource.data.managerId) || isOwnerRole();
    }
  }
}
